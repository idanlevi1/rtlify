{
  "name": "rtlify-ai",
  "version": "0.2.0",
  "description": "Zero-config RTL & Localization rules for Claude Code",
  "type": "module",
  "bin": {
    "rtlify-ai": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && cp src/rules.md dist/rules.md",
    "dev": "tsc --watch",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "rtl",
    "rtl-support",
    "right-to-left",
    "i18n",
    "localization",
    "bidi",
    "bidirectional",
    "hebrew",
    "arabic",
    "persian",
    "farsi",
    "urdu",
    "react",
    "react-native",
    "nextjs",
    "tailwind",
    "tailwindcss",
    "css-logical-properties",
    "cursor",
    "windsurf",
    "claude-code",
    "copilot",
    "ai-rules",
    "ai-coding",
    "linter",
    "frontend"
  ],
  "license": "MIT",
  "author": "Idan Levi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/idanlevi1/rtlify.git"
  },
  "bugs": {
    "url": "https://github.com/idanlevi1/rtlify/issues"
  },
  "homepage": "https://github.com/idanlevi1/rtlify#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  }
}
