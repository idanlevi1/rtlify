{
  "name": "rtlify-ai",
  "version": "0.1.0",
  "description": "Zero-config RTL & Localization rules for Claude Code",
  "type": "module",
  "bin": {
    "rtlify-ai": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && cp src/rules.md dist/rules.md",
    "dev": "tsc --watch",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "rtl",
    "i18n",
    "react",
    "tailwind",
    "hebrew",
    "arabic",
    "claude-code"
  ],
